{
  "info": {
    "name": "RaahAI Backend APIs",
    "description": "Complete collection of all endpoints for the RaahAI FastAPI MCP Server. Includes Pipeline, Dashboard, Ingestion, and Firebase Utility routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health & Root",
      "item": [
        {
          "name": "Root",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            }
          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "Pipeline",
      "item": [
        {
          "name": "Submit Raw Text",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"raw_input\": \"Please help, we need food immediately in Karachi.\",\n  \"submission_source\": \"web_form\",\n  \"assigned_ngo_id\": \"test-ngo-id\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/submit/raw",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "submit", "raw"]
            }
          }
        },
        {
          "name": "Submit Spreadsheet",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "assigned_ngo_id",
                  "value": "test-ngo-id",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/submit/spreadsheet",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "submit", "spreadsheet"]
            }
          }
        }
      ]
    },
    {
      "name": "Dashboard & Applications",
      "item": [
        {
          "name": "Dashboard Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "assigned-ngo-id",
                "value": "test-ngo-id"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/dashboard/summary",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "dashboard", "summary"]
            }
          }
        },
        {
          "name": "List Applications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "assigned-ngo-id",
                "value": "test-ngo-id"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/applications?page=1&limit=20&sort_by=latest",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "applications"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "sort_by",
                  "value": "latest"
                },
                {
                  "key": "status",
                  "value": "PENDING",
                  "disabled": true
                },
                {
                  "key": "severity",
                  "value": "CRITICAL",
                  "disabled": true
                },
                {
                  "key": "search_applicant",
                  "value": "John",
                  "disabled": true
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Ingestion",
      "item": [
        {
          "name": "Ingest CaseObject",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"case_id\": \"b392a832-1234-5678-90ab-cdef12345678\",\n  \"applicant_name\": \"Test User\",\n  \"phone\": \"03001234567\",\n  \"location_normalized\": \"Karachi\",\n  \"crisis_type\": \"food\",\n  \"dispatch_status\": \"PENDING\",\n  \"pipeline_stage\": \"INTAKE_COMPLETE\",\n  \"agent_trace\": [\n    {\n      \"agent\": \"IntakeAgent\",\n      \"timestamp\": \"2026-05-20T10:00:00Z\",\n      \"action\": \"PARSED\",\n      \"reasoning\": \"Test\",\n      \"output_summary\": \"Test\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/ingest-case",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "ingest-case"]
            }
          }
        }
      ]
    },
    {
      "name": "Firebase Utility",
      "item": [
        {
          "name": "Get Stats (Legacy)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/firebase/stats",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "firebase", "stats"]
            }
          }
        },
        {
          "name": "List All Cases",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/firebase/cases?limit=50",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "firebase", "cases"],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "status_filter",
                  "value": "PENDING",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Get Single Case",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/firebase/cases/:case_id",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "firebase", "cases", ":case_id"],
              "variable": [
                {
                  "key": "case_id",
                  "value": "replace-with-uuid"
                }
              ]
            }
          }
        },
        {
          "name": "List Volunteers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/firebase/volunteers?available=true",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "firebase", "volunteers"],
              "query": [
                {
                  "key": "available",
                  "value": "true"
                }
              ]
            }
          }
        },
        {
          "name": "Update Case Status",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"case_id\": \"replace-with-uuid\",\n  \"dispatch_status\": \"PROCESSING\",\n  \"pipeline_stage\": \"VALIDATION_COMPLETE\",\n  \"extra_fields\": {\n    \"severity_score\": 8.5\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/firebase/update-case-status",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "firebase", "update-case-status"]
            }
          }
        },
        {
          "name": "Log Trace",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"case_id\": \"replace-with-uuid\",\n  \"trace\": {\n    \"agent\": \"ValidationAgent\",\n    \"timestamp\": \"2026-05-20T10:05:00Z\",\n    \"action\": \"VALIDATED\",\n    \"reasoning\": \"Found valid phone number\",\n    \"tool_calls\": [],\n    \"output_summary\": \"Case is valid\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/firebase/log-trace",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "firebase", "log-trace"]
            }
          }
        },
