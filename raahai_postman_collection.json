              "raw": "{\n  \"ticket_id\": \"TKT-123\",\n  \"log\": {\n    \"volunteer_assigned\": \"Vol-1\",\n    \"sms_sent\": true\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/firebase/log-dispatch",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "firebase", "log-dispatch"]
            }
          }
        }
      ]
